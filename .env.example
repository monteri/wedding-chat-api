# Copy to .env for local development: cp .env.example .env

PORT=8080

DB_URL=jdbc:postgresql://localhost:5433/wedding_chat?sslmode=disable
DB_USERNAME=wedding_chat
DB_PASSWORD=wedding_chat

# Comma-separated list of allowed frontend origins (CORS + WebSocket)
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:3000

ADMIN_PASSWORD=admin123

MESSAGE_RATE_LIMIT_PER_MINUTE=12
FLOATING_REACTION_RATE_LIMIT_PER_MINUTE=30
